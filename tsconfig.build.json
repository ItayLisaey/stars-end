{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "noEmit": false,
    // Ship only .js + .d.ts; src isn't published, so maps would point nowhere.
    "sourceMap": false,
    "declarationMap": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "test"]
}
